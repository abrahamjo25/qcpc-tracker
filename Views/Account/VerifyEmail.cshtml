@model QCPCMvc.ViewModels.VerifyOtpVm
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/><link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
<title>Verify Email — QCPC</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="~/css/site.css"/>
<script>(function(){var t=localStorage.getItem('qcpc-theme')||'dark';document.documentElement.setAttribute('data-theme',t);})();</script>
</head>
<body>
<div class="auth-shell">
    <div class="auth-card" style="max-width:420px;position:relative">
        <button type="button" id="themeToggle" class="theme-toggle" style="position:absolute;top:14px;right:14px">
            <i class="bi bi-sun" id="themeIcon"></i>
        </button>

        <div class="auth-logo" style="background:linear-gradient(135deg,rgba(79,124,255,.12),rgba(124,58,237,.12));border:1px solid rgba(79,124,255,.25)">
            <i class="bi bi-shield-check" style="font-size:24px;color:#7ba6ff"></i>
        </div>

        <h1 class="auth-title">Check your email</h1>
        <p class="auth-subtitle" style="line-height:1.7">
            We sent a <strong>6-digit code</strong> to<br/>
            <span style="color:var(--accent);font-weight:600">@Model.Email</span>
        </p>

        @if (TempData["Success"] is string succ && !string.IsNullOrEmpty(succ))
        {
            <div style="display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:8px;margin-bottom:16px;font-size:13px;background:rgba(52,211,153,.08);border:1px solid rgba(52,211,153,.2);color:#34d399">
                <i class="bi bi-check-circle-fill"></i> @succ
            </div>
        }
        @if (TempData["Error"] is string err2 && !string.IsNullOrEmpty(err2))
        {
            <div class="alert-error" style="margin-bottom:16px">@err2</div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-error">
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <div>@e.ErrorMessage</div> }
            </div>
        }

        <form asp-action="VerifyEmail" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />

            <div class="form-group" style="margin-bottom:20px">
                <label style="text-align:center;display:block;margin-bottom:12px;color:var(--tx-2);font-size:13px">
                    Enter the 6-digit verification code
                </label>
                <div id="otpWrap" style="display:flex;gap:8px;justify-content:center">
                    <input type="text" inputmode="numeric" maxlength="1" pattern="[0-9]" class="otp-digit" data-index="0" autocomplete="one-time-code" />
                    <input type="text" inputmode="numeric" maxlength="1" pattern="[0-9]" class="otp-digit" data-index="1" />
                    <input type="text" inputmode="numeric" maxlength="1" pattern="[0-9]" class="otp-digit" data-index="2" />
                    <input type="text" inputmode="numeric" maxlength="1" pattern="[0-9]" class="otp-digit" data-index="3" />
                    <input type="text" inputmode="numeric" maxlength="1" pattern="[0-9]" class="otp-digit" data-index="4" />
                    <input type="text" inputmode="numeric" maxlength="1" pattern="[0-9]" class="otp-digit" data-index="5" />
                </div>
                <input asp-for="Code" type="hidden" id="codeHidden" />
            </div>

            <button type="submit" id="submitBtn" class="btn btn-primary w-full" style="justify-content:center;padding:11px" disabled>
                <i class="bi bi-check-lg"></i> Verify &amp; Create Account
            </button>
        </form>

        <div style="display:flex;align-items:center;justify-content:space-between;margin-top:20px;flex-wrap:wrap;gap:10px">
            <form asp-action="ResendOtp" method="post" style="display:inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@Model.Email" />
                <button type="submit" class="btn btn-ghost btn-sm">
                    <i class="bi bi-arrow-clockwise"></i> Resend code
                </button>
            </form>
            <a href="/Account/Register" class="btn btn-ghost btn-sm">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>

        <p style="font-size:11.5px;color:var(--tx-3);text-align:center;margin-top:18px">
            Code expires in <strong>10 minutes</strong>.
            Check your spam folder if you don't see it.
        </p>
    </div>
</div>

<style>
.otp-digit {
    width:48px;height:58px;text-align:center;
    font-size:24px;font-weight:700;font-family:sans-serif;
    border:2px solid var(--border-2);border-radius:10px;
    background:var(--bg-3);color:var(--tx-1);
    transition:border-color .15s,box-shadow .15s;
    caret-color: transparent;
}
.otp-digit:focus { outline:none;border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-glow); }
.otp-digit.filled { border-color:var(--accent);color:var(--accent); }
</style>
<script>
function applyTheme(t){document.documentElement.setAttribute('data-theme',t);localStorage.setItem('qcpc-theme',t);var i=document.getElementById('themeIcon');if(i)i.className=t==='dark'?'bi bi-sun':'bi bi-moon';}
var tb=document.getElementById('themeToggle');
if(tb){applyTheme(localStorage.getItem('qcpc-theme')||'light');tb.onclick=function(){applyTheme(document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark');};}

var digits = document.querySelectorAll('.otp-digit');
var hidden = document.getElementById('codeHidden');
var submit = document.getElementById('submitBtn');

function syncHidden(){
    var val=Array.from(digits).map(function(d){return d.value;}).join('');
    hidden.value=val;
    submit.disabled=!(val.length===6 && /^\d{6}$/.test(val));
    digits.forEach(function(d){d.classList.toggle('filled',!!d.value);});
}
digits.forEach(function(d,i){
    d.addEventListener('input',function(){
        d.value=d.value.replace(/\D/g,'').slice(-1);
        syncHidden();
        if(d.value&&i<5)digits[i+1].focus();
    });
    d.addEventListener('keydown',function(e){
        if(e.key==='Backspace'&&!d.value&&i>0){digits[i-1].focus();digits[i-1].value='';syncHidden();}
        if(e.key==='ArrowLeft'&&i>0)digits[i-1].focus();
        if(e.key==='ArrowRight'&&i<5)digits[i+1].focus();
    });
    d.addEventListener('paste',function(e){
        e.preventDefault();
        var paste=(e.clipboardData||window.clipboardData).getData('text').replace(/\D/g,'');
        paste.split('').slice(0,6).forEach(function(ch,j){if(digits[j])digits[j].value=ch;});
        syncHidden();
        digits[Math.min(paste.length,5)].focus();
    });
});
digits[0].focus();
</script>
</body>
</html>
