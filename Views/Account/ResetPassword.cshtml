@model QCPCMvc.ViewModels.ResetPasswordVm
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8" /><meta name="viewport" content="width=device-width,initial-scale=1.0"/><link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
<title>Reset Password — QCPC</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="~/css/site.css"/>
<script>(function(){var t=localStorage.getItem('qcpc-theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
</head>
<body>
<div class="auth-shell">
    <div class="auth-card">
        <button type="button" id="themeToggle" class="theme-toggle" style="position:absolute;top:14px;right:14px" title="Toggle theme">
            <i class="bi bi-sun" id="themeIcon"></i>
        </button>
        <div class="auth-logo">
            <svg width="26" height="26" viewBox="0 0 22 22" fill="none">
                <path d="M11 2L3 6V11C3 15.418 6.582 19.418 11 20C15.418 19.418 19 15.418 19 11V6L11 2Z" fill="currentColor"/>
                <path d="M8 11L10 13L14 9" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
        <h1 class="auth-title">Set new password</h1>
        <p class="auth-subtitle">Create a strong password for your account</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-error">
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <div>@e.ErrorMessage</div> }
            </div>
        }

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />
            
            <div class="form-group">
                <label>New Password</label>
                <div class="input-icon-wrap">
                    <i class="bi bi-lock"></i>
                    <input asp-for="NewPassword" type="password" class="form-control"
                           placeholder="Min 8 characters" autocomplete="new-password" />
                </div>
            </div>
            <div class="form-group">
                <label>Confirm Password</label>
                <div class="input-icon-wrap">
                    <i class="bi bi-lock-fill"></i>
                    <input asp-for="ConfirmPassword" type="password" class="form-control"
                           placeholder="Confirm your password" autocomplete="new-password" />
                </div>
            </div>
            <button type="submit" class="btn btn-primary btn-block">
                <i class="bi bi-check2-circle"></i> Reset Password
            </button>
        </form>

        <div class="auth-footer">
            <a asp-action="Login"><i class="bi bi-arrow-left"></i> Back to Sign In</a>
        </div>
    </div>
</div>

<script>
// Theme toggle
var toggleBtn = document.getElementById('themeToggle');
if (toggleBtn) {
    var curTheme = localStorage.getItem('qcpc-theme') || 'light';
    document.getElementById('themeIcon').className = curTheme === 'dark' ? 'bi bi-sun' : 'bi bi-moon';
    toggleBtn.onclick = function() {
        var t = document.documentElement.getAttribute('data-theme');
        t = t === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', t);
        localStorage.setItem('qcpc-theme', t);
        document.getElementById('themeIcon').className = t === 'dark' ? 'bi bi-sun' : 'bi bi-moon';
    };
}
</script>
</body>
</html>
