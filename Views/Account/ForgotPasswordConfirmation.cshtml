@model QCPCMvc.ViewModels.ForgotPasswordVm
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8" /><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
<title>Reset Link Sent — QCPC</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="~/css/site.css"/>
<script>(function(){var t=localStorage.getItem('qcpc-theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
</head>
<body>
<div class="auth-shell">
    <div class="auth-card" style="text-align:center;max-width:420px">
        <button type="button" id="themeToggle" class="theme-toggle" style="position:absolute;top:14px;right:14px" title="Toggle theme">
            <i class="bi bi-sun" id="themeIcon"></i>
        </button>
        <div class="auth-logo" style="margin:0 auto 20px">
            <svg width="48" height="48" viewBox="0 0 22 22" fill="none">
                <path d="M11 2L3 6V11C3 15.418 6.582 19.418 11 20C15.418 19.418 19 15.418 19 11V6L11 2Z" fill="currentColor" opacity=".9"/>
                <path d="M8 11L10 13L14 9" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
        
        <div style="width:64px;height:64px;background:linear-gradient(135deg,#22c55e,#16a34a);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px">
            <i class="bi bi-envelope-check" style="font-size:28px;color:white"></i>
        </div>
        
        <h1 class="auth-title">Check your email</h1>
        <p class="auth-subtitle">
            We've sent a password reset link to<br/>
            <strong style="color:var(--accent)">@Model.Email</strong>
        </p>

        <div style="background:var(--bg-2);border:1px solid var(--border);border-radius:12px;padding:16px;margin:20px 0;text-align:left">
            <div style="display:flex;gap:12px;align-items:flex-start">
                <i class="bi bi-info-circle" style="color:var(--accent);font-size:18px;margin-top:2px"></i>
                <div style="font-size:13px;color:var(--tx-2);line-height:1.5">
                    If you don't see the email, check your spam folder. The link will expire in 24 hours.
                </div>
            </div>
        </div>

        <a asp-action="Login" class="btn btn-primary btn-block" style="justify-content:center">
            <i class="bi bi-arrow-left"></i> Back to Sign In
        </a>
    </div>
</div>

<script>
// Theme toggle
var toggleBtn = document.getElementById('themeToggle');
if (toggleBtn) {
    var curTheme = localStorage.getItem('qcpc-theme') || 'light';
    document.getElementById('themeIcon').className = curTheme === 'dark' ? 'bi bi-sun' : 'bi bi-moon';
    toggleBtn.onclick = function() {
        var t = document.documentElement.getAttribute('data-theme');
        t = t === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', t);
        localStorage.setItem('qcpc-theme', t);
        document.getElementById('themeIcon').className = t === 'dark' ? 'bi bi-sun' : 'bi bi-moon';
    };
}
</script>
</body>
</html>
