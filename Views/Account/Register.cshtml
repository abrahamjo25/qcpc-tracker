@model QCPCMvc.ViewModels.RegisterVm
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/><link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
<title>Register — QCPC</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="~/css/site.css"/>
<script>(function(){var t=localStorage.getItem('qcpc-theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
</head>
<body>
<div class="auth-shell">
    <div class="auth-card">
        <button type="button" id="themeToggle" class="theme-toggle" style="position:absolute;top:14px;right:14px" title="Toggle theme">
            <i class="bi bi-sun" id="themeIcon"></i>
        </button>
        <div class="auth-logo"><i class="bi bi-person-plus" style="font-size:22px"></i></div>
        <h1 class="auth-title">Create account</h1>
        <p class="auth-subtitle">Ethiopian Airlines employees only</p>

        <div style="background:rgba(79,124,255,.08);border:1px solid rgba(79,124,255,.2);border-radius:8px;padding:9px 13px;margin-bottom:20px;font-size:12px;color:#7ba6ff;display:flex;align-items:center;gap:7px">
            <i class="bi bi-shield-check"></i>
            Only <strong style="margin:0 3px">@@ethiopianairlines.com</strong>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-error">
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <div>@e.ErrorMessage</div> }
            </div>
        }

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div class="form-grid-2">
                <div class="form-group">
                    <label>Full Name</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-person"></i>
                        <input asp-for="FullName" class="form-control" placeholder="Enter full name" />
                    </div>
                    <span asp-validation-for="FullName" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label>Department</label>
                    <select asp-for="DepartmentId" class="form-control">
                        <option value="">Select…</option>
                        @if (ViewBag.Departments != null)
                        {
                            @foreach (var dept in ViewBag.Departments)
                            {
                                <option value="@dept.Id">@dept.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label>Ethiopian Airlines Email</label>
                <div class="input-icon-wrap">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="Email" type="email" class="form-control"
                           placeholder="you@@ethiopianairlines.com" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
            <div class="form-grid-2">
                <div class="form-group">
                    <label>Password</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-lock"></i>
                        <input asp-for="Password" type="password" class="form-control"
                               id="p1" placeholder="Min 8 chars" />
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>
                <div class="form-group">
                    <label>Confirm Password</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-lock-fill"></i>
                        <input asp-for="Confirm" type="password" class="form-control"
                               id="p2" placeholder="Repeat password" />
                    </div>
                    <span asp-validation-for="Confirm" class="field-error"></span>
                </div>
            </div>
            <button type="submit" class="btn btn-primary w-full" style="justify-content:center;padding:10px;margin-top:4px">
                <i class="bi bi-person-check"></i> Create Account
            </button>
        </form>

        <div class="auth-footer">Already have an account? <a href="/Account/Login">Sign in</a></div>
    </div>
</div>
<script>
function tp(fId,iId){
    var f=document.getElementById(fId),i=document.getElementById(iId);
    f.type=f.type==='password'?'text':'password';
    i.className=f.type==='text'?'bi bi-eye-slash':'bi bi-eye';
}
function applyTheme(t){
    document.documentElement.setAttribute('data-theme',t);
    localStorage.setItem('qcpc-theme',t);
    var i=document.getElementById('themeIcon');
    if(i) i.className=t==='dark'?'bi bi-sun':'bi bi-moon';
}
var tb=document.getElementById('themeToggle');
if(tb){ applyTheme(localStorage.getItem('qcpc-theme')||'light'); tb.onclick=function(){ applyTheme(document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark'); }; }
</script>
</body>
</html>
