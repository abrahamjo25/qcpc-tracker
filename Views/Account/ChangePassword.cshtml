@model QCPCMvc.ViewModels.ChangePasswordVm
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="utf-8" /><meta name="viewport" content="width=device-width,initial-scale=1.0"/><link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
<title>Change Password — QCPC</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<link rel="stylesheet" href="~/css/site.css"/>
<script>(function(){var t=localStorage.getItem('qcpc-theme')||'light';document.documentElement.setAttribute('data-theme',t);})();</script>
</head>
<body>
<div class="auth-shell">
    <div class="auth-card" style="max-width:480px">
        <button type="button" id="themeToggle" class="theme-toggle" style="position:absolute;top:14px;right:14px" title="Toggle theme">
            <i class="bi bi-sun" id="themeIcon"></i>
        </button>
        <div class="auth-logo">
            <svg width="26" height="26" viewBox="0 0 22 22" fill="none">
                <path d="M11 2L3 6V11C3 15.418 6.582 19.418 11 20C15.418 19.418 19 15.418 19 11V6L11 2Z" fill="currentColor"/>
                <path d="M8 11L10 13L14 9" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>
        <h1 class="auth-title">Change Password</h1>
        <p class="auth-subtitle">Update your account password</p>

        @if (TempData["Success"] != null)
        {
            <div class="alert-success">
                <i class="bi bi-check-circle"></i> @TempData["Success"]
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert-error">
                @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                { <div>@e.ErrorMessage</div> }
            </div>
        }

        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Current Password</label>
                <div class="input-icon-wrap">
                    <i class="bi bi-lock"></i>
                    <input asp-for="CurrentPassword" type="password" class="form-control" placeholder="Enter current password" />
                </div>
            </div>
            <div class="form-group">
                <label>New Password</label>
                <div class="input-icon-wrap">
                    <i class="bi bi-key"></i>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="Enter new password (min 8 characters)" />
                </div>
            </div>
            <div class="form-group">
                <label>Confirm New Password</label>
                <div class="input-icon-wrap">
                    <i class="bi bi-key-fill"></i>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm new password" />
                </div>
            </div>
            <div style="display:flex;gap:12px;margin-top:24px">
                <button type="submit" class="btn btn-primary" style="flex:1;justify-content:center">
                    <i class="bi bi-check-lg"></i> Update Password
                </button>
                <a asp-action="Manage" class="btn btn-secondary" style="flex:1;justify-content:center;text-align:center">
                    <i class="bi bi-arrow-left"></i> Cancel
                </a>
            </div>
        </form>

        <div class="auth-footer">
            <a asp-action="Manage">&larr; Back to Profile</a>
        </div>
    </div>
</div>
<script>
function applyTheme(t){
    document.documentElement.setAttribute('data-theme',t);
    localStorage.setItem('qcpc-theme',t);
    var i=document.getElementById('themeIcon');
    if(i) i.className=t==='dark'?'bi bi-sun':'bi bi-moon';
}
var tb=document.getElementById('themeToggle');
if(tb){ applyTheme(localStorage.getItem('qcpc-theme')||'light'); tb.onclick=function(){ applyTheme(document.documentElement.getAttribute('data-theme')==='dark'?'light':'dark'); }; }
</script>
</body>
</html>
